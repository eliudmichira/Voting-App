  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "expo-start": "npx --no-install expo start",
    "expo-start-tunnel": "npx --no-install expo start --tunnel",
    "expo-start-lan": "npx --no-install expo start --lan",
    "expo-start-local": "npx --no-install expo start --localhost",
    "expo-android": "npx --no-install expo start --android",
    "expo-ios": "npx --no-install expo start --ios",
    "expo-web": "npx --no-install expo start --web",
    "update-ip": "node scripts/update-server-ip.js",
    "mobile": "npm run update-ip && npm run expo-start-lan",
    "mobile-tunnel": "npm run expo-start-tunnel",
    "android": "npm run update-ip && npm run expo-android",
    "ios": "npm run update-ip && npm run expo-ios"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
